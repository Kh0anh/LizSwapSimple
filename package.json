    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "hardhat": "^3.3.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
