    "deploy:testnet": "npx hardhat ignition deploy ./ignition/modules/deploy.ts --network bscTestnet",
    "dev": "next dev",
    "build": "next build"
  },
  "keywords": [
    "dex",
    "amm",
    "uniswap-v2",
    "bsc",
    "solidity",
    "nextjs"
  ],
