{
  "name": "lizswapsimple",
  "version": "1.0.0",
  "description": "LizSwapSimple — Sàn giao dịch phi tập trung (DEX) nguyên mẫu dựa trên AMM Uniswap V2 cho BSC",
  "private": true,
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
