# ═══════════════════════════════════════════════════════════════════════════════
# [NFR-03] LizSwapSimple — Template Biến Môi Trường
# [Task 5.4] Cập nhật địa chỉ BSC Testnet thực tế đã deploy
#
# Cách dùng: Copy file này thành .env và điền giá trị phù hợp.
# ═══════════════════════════════════════════════════════════════════════════════

# === Blockchain (Hardhat/Scripts) ===
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_MAINNET_RPC_URL=https://bsc-dataseed.binance.org/
DEPLOYER_PRIVATE_KEY=0x_YOUR_DEPLOYER_PRIVATE_KEY

# === Frontend (Next.js Public) — BSC Testnet đã deployed ===
# [Task 5.3] Contracts đã verify trên testnet.bscscan.com
NEXT_PUBLIC_CHAIN_ID=97
NEXT_PUBLIC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
NEXT_PUBLIC_ROUTER_ADDRESS=0xAaa9015dB17062ea4C5342bC47Db688574d70515
NEXT_PUBLIC_FACTORY_ADDRESS=0x8b419c98c94Bd26Fd10eaB41C2A97826faf80105
NEXT_PUBLIC_ALLOW_DEPLOYED_FALLBACK=true

# === Docker Web Ports / SSL ===
# Mac dinh web publish qua cong 80 tren host
HTTP_PORT=80

# HTTPS chi dung khi chay them file docker-compose.ssl.yml
HTTPS_PORT=443

# Duong dan mount thu muc chung chi SSL vao nginx container
# Thu muc nay can co:
#   fullchain.pem
#   privkey.pem
SSL_CERTS_PATH=./ssl

# File nginx config khi bat SSL override
NGINX_SSL_CONFIG_PATH=./nginx.ssl.conf

# === Local Development (Hardhat Node localhost:8545) ===
# Bỏ comment 3 dòng dưới đây và comment 3 dòng testnet ở trên khi chạy local:
# NEXT_PUBLIC_CHAIN_ID=31337
# NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545/
# NEXT_PUBLIC_ROUTER_ADDRESS=0x_LOCAL_ROUTER
# NEXT_PUBLIC_FACTORY_ADDRESS=0x_LOCAL_FACTORY
